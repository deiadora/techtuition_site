  <script>

    document.getElementById("year").textContent = new Date().getFullYear();

    const toggle  = document.getElementById("themeToggle");
    const root    = document.documentElement;
    const STORE   = "qc-theme";
    const sysDark = window.matchMedia("(prefers-color-scheme: dark)");
    function resolveTheme() {
      const saved = localStorage.getItem(STORE);
      if (saved) return saved;
      return sysDark.matches ? "dark" : "light";
    }
    function applyTheme(theme) {
      root.setAttribute("data-theme", theme);
      const isSystem = !localStorage.getItem(STORE);
      toggle.textContent = isSystem ? "\u{1F317}" : (theme === "dark" ? "\u{1F319}" : "\u2600\uFE0F");
      toggle.setAttribute("aria-label", theme === "dark" ? "switch to light mode" : "switch to dark mode");
    }
    applyTheme(resolveTheme());
    toggle.addEventListener("click", () => {
      const current = root.getAttribute("data-theme");
      const sysTheme = sysDark.matches ? "dark" : "light";
      const next = current === "dark" ? "light" : "dark";
      if (next === sysTheme) { localStorage.removeItem(STORE); }
      else { localStorage.setItem(STORE, next); }
      applyTheme(next);
    });
    sysDark.addEventListener("change", () => {
      if (!localStorage.getItem(STORE)) {
        applyTheme(sysDark.matches ? "dark" : "light");
      }
    });

    const textToggle = document.getElementById("textToggle");
    const TEXT_STORE = "qc-textsize";
    function applyTextSize(size) {
      if (size === "large") {
        root.setAttribute("data-textsize", "large");
        textToggle.setAttribute("aria-pressed", "true");
        textToggle.setAttribute("aria-label", "switch to normal text size");
      } else {
        root.removeAttribute("data-textsize");
        textToggle.setAttribute("aria-pressed", "false");
        textToggle.setAttribute("aria-label", "switch to larger text size");
      }
    }
    applyTextSize(localStorage.getItem(TEXT_STORE) || "normal");
    textToggle.addEventListener("click", () => {
      const next = root.hasAttribute("data-textsize") ? "normal" : "large";
      if (next === "large") { localStorage.setItem(TEXT_STORE, "large"); }
      else { localStorage.removeItem(TEXT_STORE); }
      applyTextSize(next);
    });

  </script>
